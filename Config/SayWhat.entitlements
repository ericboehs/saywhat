<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox on: privacy posture. Recordings live in the app container. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Microphone capture. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- Outbound only: first-run ML model download (FluidAudio Sortformer/
	     Parakeet from HuggingFace) and optional calendar lookup. No server, no
	     telemetry, no audio/transcript ever leaves the machine. DESIGN.md §3. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
