# Xcode / SPM
.DS_Store
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout
DerivedData/
build/
.build/
.swiftpm/
Package.resolved

# The vanilla SayWhat.xcodeproj is committed (no generator — see QUALITY.md
# "Project gen"). Ignore only its user-specific and resolved-package bits;
# xcuserdata/ and Package.resolved are already covered above.
*.xcworkspace/xcuserdata/

# Tooling
.netrc
*.profraw
*.profdata
coverage/
*.lcov

# Models (downloaded at runtime — never commit; can be GBs)
Models/*.mlmodelc
Models/*.gguf
Models/*.safetensors
*.mlpackage

# Recordings & local data (never commit user audio/transcripts)
Recordings/
*.m4a
*.wav
*.caf

# Secrets
.env
*.p8
*.p12
*.mobileprovision

# Per-developer signing override (team/identity stays out of the repo)
Config/Local.xcconfig

# Claude Code: track shared config + hooks, ignore local overrides.
# (.claude is ignored by the global gitignore; these files are force-added.)
.claude/settings.local.json
.claude/*.local.json
